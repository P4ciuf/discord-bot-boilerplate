{
	"name": "discord-bot-boilerplate",
	"version": "1.0.0",
	"description": "Scalable and maintainable Discord bot base built with TypeScript, dotenv, and Mongoose",
	"main": "dist/index.js",
	"type": "module",
	"scripts": {
		"test": "bun src/main.ts",
		"start": "npm run build && node dist/main.cjs",
		"build": "tsup src/**/* --minify --platform node",
		"lint": "eslint . --ext .ts",
		"lint:fix": "eslint . --ext .ts --fix",
		"prettier": "prettier --check --write ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/P4ciuf/discord-bot-boilerplate.git"
	},
	"keywords": [
		"discord-bot",
		"discord-bot-template",
		"discord.js",
		"boilerplate"
	],
	"author": "P4ciuf | p4ciuf@gmail.com",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/P4ciuf/discord-bot-boilerplate/issues"
	},
	"homepage": "https://github.com/P4ciuf/discord-bot-boilerplate#readme",
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@types/eslint": "^9.6.1",
		"@types/ms": "^2.1.0",
		"@types/node": "^25.0.1",
		"bun-types": "^1.3.4",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"globals": "^16.5.0",
		"prettier": "^3.7.4",
		"typescript-eslint": "^8.49.0"
	},
	"dependencies": {
		"discord.js": "^14.25.1",
		"dotenv": "^17.2.3",
		"mongoose": "^9.0.1",
		"ms": "^2.1.3",
		"tsup": "^8.5.1",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0"
	}
}
